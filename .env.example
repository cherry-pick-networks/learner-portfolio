# Copy to .env. Do not commit.
# Required for Docker / docker compose:

# Optional:
# API_PORT=
# SQLITE_PATH=./data/learner_portfolio.db

# Required for Kùzu Explorer:
# KUZU_EXPLORER_PORT=
# KUZU_PATH=./data/knowledge_graph

# Required for OpenAI:
# OPENAI_API_KEY=sk-...

# Required for Entra ID OAuth:
# ENTRA_TENANT_ID=
# ENTRA_CLIENT_ID=

# Required for GitHub:
# GITHUB_PERSONAL_ACCESS_TOKEN=ghp_...
